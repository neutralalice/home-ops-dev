{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "docker:enableMajor",
    "security:openssf-scorecard",
    ":automergeBranch",
    ":automergeDigest",
    ":automergePatch",
    ":disableRateLimiting",
    ":semanticCommits",
    "github>neutralalice/home-ops-dev//.github/renovate/autoMerge.json5",
    "github>neutralalice/home-ops-dev//.github/renovate/changelogs.json5",
    "github>neutralalice/home-ops-dev//.github/renovate/customManagers.json5",
    "github>neutralalice/home-ops-dev//.github/renovate/grafanaDashboards.json5",
    "github>neutralalice/home-ops-dev//.github/renovate/groups.json5",
    "github>neutralalice/home-ops-dev//.github/renovate/labels.json5",
    "github>neutralalice/home-ops-dev//.github/renovate/semanticCommits.json5",
  ],
  dependencyDashboardAutoclose: true,
  dependencyDashboardTitle: "Renovate Dashboard",
  minimumReleaseAge: "1 days",
  enabledManagers: [
    "flux",
    "github-actions",
    "helm-values",
    "helmfile",
    "kubernetes",
    "mise",
    "renovate-config",
    "custom.regex",
  ],
  suppressNotifications: ["prEditedNotification", "prIgnoreNotification"],
  flux: {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
  "helm-values": {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
  kubernetes: {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
}
